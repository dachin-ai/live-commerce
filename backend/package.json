{
  "name": "live-commerce-backend",
  "version": "1.0.0",
  "description": "直播电商中台后端API",
  "main": "dist/index.js",
  "scripts": {
    "postinstall": "patch-package",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:update-seed": "tsx src/db-migrate.ts",
    "db:seed-test-users": "tsx scripts/seed-test-users.ts",
    "db:reset": "node -e \"const fs = require('fs'); if (fs.existsSync('data.db')) { fs.unlinkSync('data.db'); console.log('✅ 数据库已删除'); } else { console.log('ℹ️  数据库不存在'); }\"",
    "db:clean-stats": "tsx scripts/clean-stats-duplicates.ts",
    "db:clean-monthly-orphan": "tsx scripts/clean-monthly-orphan-stats.ts",
    "db:inspect": "tsx scripts/inspect-db.ts",
    "db:clear-import": "tsx scripts/clear-import-data.ts",
    "db:reset-full": "tsx scripts/reset-database.ts",
    "test:generate-logic": "tsx scripts/test-generate-logic.ts",
    "test:generate-api": "tsx scripts/test-generate-tasks-api.ts",
    "test:script-fallback": "tsx scripts/test-script-fallback.ts"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "google-translate-api-x": "^10.7.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.1",
    "sqlite3": "^5.1.7",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.4",
    "@types/nodemailer": "^7.0.9",
    "@types/sqlite3": "^3.1.11",
    "@types/xlsx": "^0.0.36",
    "patch-package": "^8.0.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
