# 复制本文件为 .env 并按需填写，不要提交 .env 到版本库

# 服务端口（可选，默认 3000）
# PORT=3000

# 视频分析用：Vision/Coze 模型需访问视频 URL，生产部署必须配置公网地址
# API_BASE_URL=https://你的域名.com
# 或 PUBLIC_URL=https://你的域名.com
# 运行环境（生产部署建议设为 production）
# NODE_ENV=production

# 登录 JWT 密钥（生产环境务必修改）
# JWT_SECRET=your-secret-key-change-in-production

# 话术/待办 LLM（可选，也可在管理后台配置）
# SCRIPT_LLM_URL=
# SCRIPT_LLM_API_KEY=

# *.coze.site 鉴权兜底：未配 SCRIPT_LLM_API_KEY 时使用（可选）
# AGENT_API_KEY=

# 请求体格式：仅当自建 Agent 且接口只支持 { content, session_id } 时设 1；*.coze.site 使用 legacy 体，勿设
# AGENT_API_BODY=1

# 通过 API 与智能体 Bot 交互（POST /api/ai/bot/generate-tasks）时的 API Key，不配置则该接口返回 503
# BOT_API_KEY=

# 邮箱认证（忘记密码发验证码），不配置则不发邮件，开发环境会在接口响应中返回验证码
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=
# SMTP_USER=
# SMTP_PASS=
# MAIL_FROM=
# APP_NAME=直播电商中台
