# ── Backend Environment Variables ──────────────────────────────

# Node environment (production | development)
NODE_ENV=production

# JWT secret for authentication (REQUIRED - use a strong random string)
JWT_SECRET=change_me_to_a_strong_random_string

# CORS origin (REQUIRED - must match the frontend URL exactly)
# Example: https://live-commerce-web-416645281925.asia-southeast1.run.app
CORS_ORIGIN=http://localhost:5173

# ── Database (Optional - falls back to SQLite if not set) ─────
# Set PG_HOST to enable PostgreSQL mode.
# If PG_HOST is not set, the backend uses an embedded SQLite file (data/local.db).

# PG_HOST=localhost
# PG_PORT=5432
# PG_DATABASE=live_commerce
# PG_USER=lvbcsym
# PG_PASSWORD=your_password

# For Cloud SQL via Unix socket:
# PG_HOST=/cloudsql/PROJECT:REGION:INSTANCE

# ── Email (Optional - for password reset) ─────────────────────
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=noreply@example.com
# SMTP_PASS=your_smtp_password
# SMTP_FROM=noreply@example.com

# ── LLM APIs (Optional - for AI features) ─────────────────────
# COZE_API_KEY=your_coze_api_key
# COZE_BOT_ID=your_coze_bot_id
# GEMINI_API_KEY=your_gemini_api_key
